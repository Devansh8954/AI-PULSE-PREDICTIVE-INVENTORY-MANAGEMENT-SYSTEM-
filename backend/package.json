{
  "name": "ai-pulse-backend",
  "version": "1.0.0",
  "description": "AI-Pulse Predictive Inventory – Node.js REST API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch --runInBand",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "lint": "eslint \"src/**/*.js\" \"tests/**/*.js\"",
    "lint:fix": "eslint \"src/**/*.js\" \"tests/**/*.js\" --fix",
    "db:sync":       "node src/scripts/syncDb.js",
    "db:seed-users": "node src/scripts/seedUsers.js",
    "db:seed-all":   "node src/scripts/seedAll.js",
    "db:setup":      "node src/scripts/fixAndSeedUsers.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "mysql2": "^3.6.5",
    "sequelize": "^6.35.2",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": [
      "src/services/**/*.js",
      "src/controllers/**/*.js",
      "src/middlewares/**/*.js",
      "!src/scripts/**",
      "!src/config/**"
    ],
    "coverageThresholds": {
      "global": {
        "lines":     60,
        "functions": 60,
        "branches":  50,
        "statements": 60
      }
    },
    "coverageReporters": ["text", "lcov", "html"]
  }
}
