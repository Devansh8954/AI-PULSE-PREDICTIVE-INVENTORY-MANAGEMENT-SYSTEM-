# =============================================================================
# AI-Pulse Backend — Environment Variables TEMPLATE
# =============================================================================
# ✅  Copy this file to `.env` and fill in your real values.
#     $ cp .env.example .env
# ⚠️  NEVER put real secrets in this file — it IS committed to the repo.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database (MySQL) ──────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ai_pulse_db
DB_USER=root
DB_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET=
JWT_EXPIRES_IN=24h

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:4200

# ── Google Gemini AI ──────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Rate Limiter ──────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Bcrypt ────────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12
