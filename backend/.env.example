# ============================================================
# AI-Pulse Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development          # development | production | test
LOG_LEVEL=debug               # error | warn | info | debug

# ── MySQL Database ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ai_pulse_db
DB_USER=root
DB_PASSWORD=your_db_password_here

# ── JWT Authentication ────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_STRING
JWT_EXPIRES_IN=24h

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:4200

# ── AI / Gemini API ───────────────────────────────────────────
# How to get your key:
#  1. Go to https://aistudio.google.com/app/apikey
#  2. Click "Create API Key"
#  3. Copy the key and paste it below.
#
# SECURITY RULES (read carefully):
#  ✅ Store ONLY in this .env file (or a secrets manager in production).
#  ✅ Add .env to .gitignore — NEVER commit this file.
#  ✅ In production, inject via environment variables (Railway, Render, AWS SSM, etc.).
#  ✅ Rotate the key immediately if it is ever accidentally exposed.
#  ❌ Never hardcode in source files.
#  ❌ Never log the key (even in debug mode).
#  ❌ Never share in Slack, email, or GitHub Issues.
#
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# (Alternative) OpenAI — use if you switch AI providers
# OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
# OPENAI_MODEL=gpt-4o

# ── Trend Analysis Configuration ─────────────────────────────
# Items with stock below this value + flagged as trending → signal is written
TREND_RESTOCK_THRESHOLD=50

# How many days a trend signal remains active for forecasting
TREND_SIGNAL_TTL_DAYS=7
